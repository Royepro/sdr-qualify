# ── Pipedrive OAuth ──────────────────────────────
# Get from: https://developers.pipedrive.com → Your Apps
PIPEDRIVE_CLIENT_ID=your_client_id_here
PIPEDRIVE_CLIENT_SECRET=your_client_secret_here

# Must match EXACTLY what you set in Pipedrive Developer Hub:
PIPEDRIVE_REDIRECT_URI=https://YOUR-APP.vercel.app/api/auth/callback

# ── Session Security ─────────────────────────────
# Any long random string (min 32 chars):
SESSION_SECRET=change-this-to-a-long-random-secret-string-32chars

# ── Admin ────────────────────────────────────────
ADMIN_EMAIL=roye@contel.co.il

# ── Optional: fallback token for testing ─────────
# PD_TOKEN=your_personal_api_token
